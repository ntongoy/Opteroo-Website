# Opteroo Website - Environment Variables
# Copy to .env and adjust for your environment.

# Backend API base URL (Laravel Opteroo-ai)
# - Local: http://127.0.0.1:8181 (when Laravel runs on 8181)
# - Staging: https://opteroo-api-staging.on-forge.com
REACT_APP_BACKEND_URL=http://127.0.0.1:8181

# Webpack dev server WebSocket port (for HMR behind proxy)
# Use 443 when served over HTTPS proxy; omit or match PORT for local dev
WDS_SOCKET_PORT=3000

# Enable health-check plugin and dev server endpoints
ENABLE_HEALTH_CHECK=false

# --- EOI Admin Notification (Vercel serverless /api/eoi-admin-notify) ---
# Required for admin email when new Expression of Interest is submitted
MAIL_ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-smtp-user
SMTP_PASSWORD=your-brevo-smtp-password
# Optional
SMTP_FROM=noreply@opteroo.ai
APP_BRAND_NAME=Opteroo
